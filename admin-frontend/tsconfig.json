{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@styles/*": ["./src/styles/*"],
      "styles/app.scss": ["./src/styles/app.scss"],
      "@modules/shared/*": ["./src/modules/shared/*"],
      "@modules/auth": ["./src/modules/auth/index"],
      "@modules/auth/*": ["./src/modules/auth/*"],
      "@modules/dashboard": ["./src/modules/dashboard/index"],
      "@modules/dashboard/*": ["./src/modules/dashboard/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
