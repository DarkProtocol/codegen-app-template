# Local environment configuration.
# Copy this file to .env and adjust as needed.
# In production, set environment variables via server or container configuration instead.
ENVIRONMENT=dev

DB_HOST=postgres
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DATABASE=0

OBJECT_STORAGE_PROVIDER=file
# Set OBJECT_STORAGE_PROVIDER=nop to disable object storage.
OBJECT_STORAGE_ROOT_PATH=/app/runtime/uploads
# Optional public uploads base URL. When set, file publicUrl uses this host instead of the admin API host.
# PUBLIC_UPLOADS_BASE_URL=https://cdn.app.test

ADMIN_AUTH_JWT_SECRET=change-me-to-a-random-32-byte-secret
